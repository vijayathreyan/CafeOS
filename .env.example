# ============================================================
# Unlimited Food Works — CafeOS Environment Variables
# Copy this file to .env and fill in all values before running
# ============================================================

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=cafeos

# --- Supabase JWT Secrets (generate with: openssl rand -base64 32) ---
JWT_SECRET=change_this_jwt_secret_minimum_32_chars
ANON_KEY=your_supabase_anon_key_here
SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Supabase Auth (GoTrue) ---
GOTRUE_JWT_SECRET=${JWT_SECRET}
GOTRUE_JWT_EXP=28800
GOTRUE_DB_DRIVER=postgres
GOTRUE_DB_DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?search_path=auth
GOTRUE_API_HOST=0.0.0.0
GOTRUE_API_PORT=9999
GOTRUE_SITE_URL=http://localhost
API_EXTERNAL_URL=http://localhost
GOTRUE_DISABLE_SIGNUP=true
GOTRUE_MAILER_AUTOCONFIRM=true
GOTRUE_SMS_AUTOCONFIRM=true

# --- PostgREST ---
PGRST_DB_URI=postgres://postgres:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
PGRST_DB_SCHEMA=public
PGRST_DB_ANON_ROLE=anon
PGRST_JWT_SECRET=${JWT_SECRET}
PGRST_DB_USE_LEGACY_GUCS=false

# --- Supabase Storage ---
STORAGE_BACKEND=file
FILE_STORAGE_BACKEND_PATH=/var/lib/storage
STORAGE_FILE_BACKEND_MAX_FILE_SIZE=52428800
ANON_KEY_STORAGE=${ANON_KEY}
SERVICE_KEY_STORAGE=${SERVICE_ROLE_KEY}
TENANT_ID=cafeos
REGION=ap-south-1
POSTGREST_URL=http://supabase-api:3000

# --- App ---
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=${ANON_KEY}
VITE_APP_NAME=CafeOS

# --- Meta WhatsApp Cloud API ---
WHATSAPP_TOKEN=your_meta_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=change_this_verify_token

# --- Fast2SMS (SMS alerts) ---
FAST2SMS_API_KEY=your_fast2sms_api_key

# --- Nginx ---
DOMAIN=localhost
